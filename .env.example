# The local dev runtime (twilio serverless:start) reads ACCOUNT_SID and AUTH_TOKEN.
# When deployed, you can set these in the Twilio Console under your Functions Service environment.
ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH_TOKEN=your_auth_token

# Verify Service SID — must have "Custom Verification Code" enabled
# Console: Verify → Services → <your service> → General → Enable Custom Verification Code
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret PingOne sends as: Authorization: Bearer <value>
# Generate a long random string, e.g.: openssl rand -hex 32
PINGONE_SHARED_SECRET=replace_with_a_long_random_secret
